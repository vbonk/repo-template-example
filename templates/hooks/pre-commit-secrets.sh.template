#!/usr/bin/env bash
# Pre-commit hook: blocks commits containing secrets or forbidden tokens.
# Install: cp templates/hooks/pre-commit-secrets.sh.template .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: bash templates/hooks/setup-hooks.sh
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
TOKENS_FILE="$REPO_ROOT/.git/hooks/forbidden-tokens.txt"
BLOCKED=0

echo "=== Pre-commit security check ==="

# --- Check 1: Forbidden tokens (from file + dynamic username) ---
TOKENS=()

# Dynamic: detect local username across platforms
for var in USER LOGNAME USERNAME; do
  val="${!var:-}"
  if [[ -n "$val" ]]; then
    TOKENS+=("$val")
  fi
done

# From file (if exists)
if [[ -f "$TOKENS_FILE" ]]; then
  while IFS= read -r line; do
    line="${line%%#*}"
    line="$(echo "$line" | xargs 2>/dev/null || echo "$line")"
    [[ -z "$line" ]] && continue
    TOKENS+=("$line")
  done < "$TOKENS_FILE"
fi

# Deduplicate
if [[ ${#TOKENS[@]} -gt 0 ]]; then
  mapfile -t TOKENS < <(printf '%s\n' "${TOKENS[@]}" | sort -u)
fi

# Get staged files (exclude binaries and lock files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- \
  ':!pnpm-lock.yaml' ':!package-lock.json' ':!yarn.lock' ':!Cargo.lock' ':!go.sum' \
  ':!*.png' ':!*.jpg' ':!*.jpeg' ':!*.gif' ':!*.ico' ':!*.webp' \
  ':!*.woff' ':!*.woff2' ':!*.ttf' ':!*.eot' ':!*.svg' \
  ':!*.zip' ':!*.tar' ':!*.gz' ':!*.pdf' 2>/dev/null || true)

# Scan staged files for forbidden tokens
if [[ -n "$STAGED_FILES" && ${#TOKENS[@]} -gt 0 ]]; then
  for token in "${TOKENS[@]}"; do
    matches=$(echo "$STAGED_FILES" | while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      git show ":$f" 2>/dev/null | grep -in -- "$token" | while IFS= read -r match; do
        echo "  $f:$match"
      done
    done || true)

    if [[ -n "$matches" ]]; then
      if [[ $BLOCKED -eq 0 ]]; then
        echo -e "${RED}BLOCKED: Forbidden tokens found in staged files:${NC}"
      fi
      echo -e "${YELLOW}  Token: ${token}${NC}"
      echo "$matches"
      BLOCKED=1
    fi
  done
fi

# --- Check 2: Secret patterns (regex) ---
# Uses [[:space:]] for POSIX compatibility (works on macOS BSD grep and GNU grep)
SECRET_PATTERNS=(
  'PRIVATE.KEY'
  'BEGIN RSA'
  'BEGIN OPENSSH'
  'BEGIN EC PRIVATE'
  'BEGIN PGP PRIVATE'
  'password[[:space:]]*[:=][[:space:]]*["\x27][^"\x27]{8,}'
  'secret[[:space:]]*[:=][[:space:]]*["\x27][^"\x27]{8,}'
  'api[_-]?key[[:space:]]*[:=][[:space:]]*["\x27][^"\x27]{8,}'
  'token[[:space:]]*[:=][[:space:]]*["\x27][^"\x27]{8,}'
  'aws_access_key_id[[:space:]]*='
  'aws_secret_access_key[[:space:]]*='
  'AKIA[A-Z0-9]{16}'
  'ghp_[a-zA-Z0-9]{36}'
  'gho_[a-zA-Z0-9]{36}'
  'ghs_[a-zA-Z0-9]{36}'
  'sk-ant-[a-zA-Z0-9]+'
  'sk-proj-[a-zA-Z0-9]+'
)

if [[ -n "$STAGED_FILES" ]]; then
  for pattern in "${SECRET_PATTERNS[@]}"; do
    matches=$(echo "$STAGED_FILES" | while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      # Skip files that legitimately contain secret patterns (docs, templates, security tooling)
      case "$f" in
        *.example|*.md|*.txt|*.template) continue ;;
        templates/hooks/*|.github/workflows/secret-scan-pr.yml|.github/workflows/validate-template.yml) continue ;;
      esac
      git show ":$f" 2>/dev/null | grep -iEn -- "$pattern" | while IFS= read -r match; do
        echo "  $f:$match"
      done
    done || true)

    if [[ -n "$matches" ]]; then
      if [[ $BLOCKED -eq 0 ]]; then
        echo -e "${RED}BLOCKED: Possible secrets detected in staged files:${NC}"
      fi
      echo -e "${YELLOW}  Pattern: ${pattern}${NC}"
      echo "$matches"
      BLOCKED=1
    fi
  done
fi

# --- Check 3: .env files ---
ENV_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.env($|\.)' | grep -v '\.example' || true)
if [[ -n "$ENV_FILES" ]]; then
  echo -e "${RED}BLOCKED: .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES"
  BLOCKED=1
fi

# --- Result ---
if [[ $BLOCKED -ne 0 ]]; then
  echo ""
  echo -e "${RED}Commit blocked. Fix the issues above, then try again.${NC}"
  echo "If a detection is a false positive, you can:"
  echo "  1. Add an exclusion pattern to the hook"
  echo "  2. Use 'git commit --no-verify' (use sparingly and document why)"
  exit 1
fi

echo -e "${GREEN}All checks passed.${NC}"
exit 0
